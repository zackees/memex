{
  "name": "memex",
  "version": "1.0.0",
  "description": "SQLite HTTP range-request client for memex databases",
  "type": "module",
  "scripts": {
    "build": "npm run build:wasm && npm run build:js && npm run build:demo",
    "build:wasm": "webpack --config webpack.browser.config.js && cp demo.html ../dist/wasm/demo.html && rm -f ../dist/wasm/*.LICENSE.txt",
    "build:js": "webpack --config webpack.node.config.js && cp demo.html ../dist/js/demo.html",
    "build:demo": "webpack --config webpack.config.js"
  },
  "license": "ISC",
  "dependencies": {
    "sqlite-wasm-http": "^1.2.0",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  }
}
